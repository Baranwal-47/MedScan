# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
MONGO_DB_NAME=medicine_db
PORT=5001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
JWT_SECRET=<long-random-string>

# Cloudinary (image storage: avatars + prescription scans)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gmail SMTP (verification codes, order updates, reminders) — use an App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OCR chain — Gemini is primary; ocr.space is the fallback
GEMINI_API_KEY=
OCR_SPACE_API_KEY=
# Optional: enables the TrOCR fallback stage
# HUGGINGFACE_API_KEY=
