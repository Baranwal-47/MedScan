# Root-level ignores for MedScan project

# Environment variables (secrets)
.env
.env.local
.env.*.local

# IDE and editor
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# Logs
logs
*.log
npm-debug.log*

# Runtime data
pids
*.pid

# Session/handoff documentation
COPILOT_HANDOFF.md
.copilot-handoff

# Build outputs (if any at root)
dist
build

# Dependency directories at root (if monorepo patterns exist)
node_modules

# Temporary files
*.tmp
.temp

# OS files
Thumbs.db
